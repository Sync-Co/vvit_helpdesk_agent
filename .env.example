# Copy this file to .env and fill in your values

# Required: OpenAI API Key
OPENAI_API_KEY=sk-...

# Optional: LangSmith tracing (highly recommended for live demo — shows agent routing in real time)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=vvit-helpdesk-agent

# Required: Streamlit Private Access Code for the UI
APP_PASSWORD=
